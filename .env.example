ANTHROPIC_API_KEY=your_api_key_here
TAVILY_API_KEY=your_tavily_api_key_here
EXA_API_KEY=your_exa_api_key_here
PORT=3001
# Comma-separated allowed CORS origins for the frontend. Leave unset locally —
# defaults to http://localhost:5173,http://127.0.0.1:5173. In production, set
# to your deployed frontend's real origin (e.g. https://pickleball-coach.vercel.app).
CORS_ORIGIN=
# Overrides where DUPR history snapshots/index are read/written. Leave unset
# locally to use backend/data/dupr-history. In production this should point at
# a persistent disk mount path (e.g. /var/data/dupr-history on Render).
DUPR_HISTORY_DIR=
