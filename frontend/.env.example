# Base URL of the deployed backend API (no trailing slash), e.g.:
# VITE_API_URL=https://pickleball-coach-api.onrender.com
#
# Leave blank/unset for local development — the app falls back to relative
# /api paths, which Vite's dev server proxies to http://localhost:3001
# (see frontend/vite.config.js).
VITE_API_URL=
